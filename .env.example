APP_NAME="Moz Acad"
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Africa/Maputo
APP_LOCALE=pt_MZ
SESSION_SAMESITE=Strict

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=moz_acad
DB_USERNAME=root
DB_PASSWORD=

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5
OPENAI_MODEL_STRUCTURE=gpt-5
OPENAI_MODEL_CONTENT=gpt-5
OPENAI_MODEL_REFINEMENT=gpt-5
OPENAI_MODEL_HUMANIZER=gpt-5
OPENAI_TIMEOUT=60
OPENAI_MAX_OUTPUT_TOKENS=4000
OPENAI_TEMPERATURE=0.7
OPENAI_ENABLE_STRUCTURED_OUTPUT=true
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MODEL_STRUCTURE=gemini-1.5-flash
GEMINI_MODEL_CONTENT=gemini-1.5-flash
GEMINI_MODEL_REFINEMENT=gemini-1.5-flash
GEMINI_MODEL_HUMANIZER=gemini-1.5-flash
GEMINI_TIMEOUT=60
GEMINI_MAX_OUTPUT_TOKENS=4000
GEMINI_TEMPERATURE=0.7
AI_JOB_BATCH_LIMIT=5
AI_JOB_STALE_PROCESSING_TIMEOUT=1800
WORKER_LOOP_INTERVAL_SECONDS=30
WORKER_RUN_ONCE=false
QUEUE_STALE_QUEUED_MINUTES=10
QUEUE_STALE_PROCESSING_MINUTES=30

DEBITO_BASE_URL=https://gyqoaningqhurhvdugne.supabase.co/functions/v1
DEBITO_TOKEN=
DEBITO_MERCHANT_ID=
DEBITO_WALLET_CODE=
DEBITO_CURRENCY=MZN
DEBITO_CALLBACK_URL=
DEBITO_WEBHOOK_PATH=/webhooks/debito
DEBITO_WEBHOOK_SECRET=
DEBITO_ALLOW_UNSIGNED_WEBHOOK_LOCAL=false
DEBITO_TIMEOUT=30
DEBITO_HTTP_RETRIES=2
DEBITO_HTTP_BACKOFF_MS=500
DEBITO_POLLING_ENABLED=true
DEBITO_POLLING_BATCH_LIMIT=20
DEBITO_ENABLE_WEBHOOK=true
DEBITO_WEBHOOK_REPLAY_TTL_SECONDS=86400
DEBITO_WEBHOOK_MAX_SKEW_SECONDS=900
DEBITO_WEBHOOK_REQUIRE_TIMESTAMP=true
# Produção exige DEBITO_TOKEN, DEBITO_MERCHANT_ID, DEBITO_WALLET_CODE e DEBITO_WEBHOOK_SECRET.
# Não usar wallet_id interno; não expor sk_live/sk_sandbox no frontend.

MPESA_MSISDN_REGEX=/^(84|85)\d{7}$/
MPESA_COUNTRY_CODE=MZ

INVOICE_PREFIX=MZA
PAYMENT_REFERENCE_PREFIX=PAY
ORDER_REFERENCE_PREFIX=ORD

PRICING_CURRENCY=MZN
PRICING_BASE_TRABALHO_PESQUISA=800
PRICING_BASE_PROJECTO_PESQUISA=1500
PRICING_BASE_MONOGRAFIA=4500
PRICING_BASE_RELATORIO_ESTAGIO=2000
PRICING_BASE_ARTIGO_CIENTIFICO=1200
PRICING_BASE_RESAENHA_CRITICA=700
PRICING_BASE_ENSAIO_ACADEMICO=900
PRICING_BASE_TRABALHO_CAMPO=1800
PRICING_BASE_REVISAO_LITERATURA=1400
PRICING_BASE_ESTUDO_CASO=1600
PRICING_BASE_PROPOSTA_TCC=1700

PRICING_PER_PAGE_DEFAULT=40
PRICING_INCLUDED_PAGES_DEFAULT=10

PRICING_LEVEL_TECNICO_MULTIPLIER=1.0
PRICING_LEVEL_LICENCIATURA_MULTIPLIER=1.2
PRICING_LEVEL_POS_GRADUACAO_MULTIPLIER=1.35
PRICING_LEVEL_MESTRADO_MULTIPLIER=1.6
PRICING_LEVEL_DOUTORAMENTO_MULTIPLIER=2.0

PRICING_COMPLEXITY_LOW_MULTIPLIER=1.0
PRICING_COMPLEXITY_MEDIUM_MULTIPLIER=1.15
PRICING_COMPLEXITY_HIGH_MULTIPLIER=1.35
PRICING_COMPLEXITY_VERY_HIGH_MULTIPLIER=1.60

PRICING_URGENCY_NORMAL_MULTIPLIER=1.0
PRICING_URGENCY_FAST_MULTIPLIER=1.2
PRICING_URGENCY_EXPRESS_MULTIPLIER=1.5
PRICING_URGENCY_ULTRA_MULTIPLIER=2.0

PRICING_EXTRA_CAPA_PERSONALIZADA=200
PRICING_EXTRA_ABSTRACT_BILINGUE=300
PRICING_EXTRA_REFERENCIAS_PREMIUM=250
PRICING_EXTRA_REVISAO_METODOLOGICA=500
PRICING_EXTRA_REVISAO_HUMANIZADA=400
PRICING_EXTRA_APRESENTACAO_SLIDES=800
PRICING_EXTRA_RESUMO_DEFESA=450
PRICING_HUMAN_REVIEW_MONOGRAFIA=1500

PRICING_MIN_ORDER_AMOUNT=500
PRICING_ENABLE_DB_OVERRIDES=true

STORAGE_GENERATED_PATH=storage/generated
STORAGE_TEMPLATES_PATH=storage/templates
STORAGE_LOGS_PATH=storage/logs
STORAGE_UPLOADS_PATH=storage/uploads
STORAGE_NORMS_PATH=storage/norms
STORAGE_DIR_MODE=0770
# Logs operacionais adicionais: storage/logs/application.log
LOG_MAX_FILE_SIZE_MB=20
LOG_MAX_ROTATED_FILES=5
LOG_FILE_PERMISSIONS=0600

UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_MIME=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
UPLOAD_ALLOWED_EXTENSIONS=pdf,doc,docx,txt
UPLOAD_ANTIMALWARE_ENABLED=false
UPLOAD_ANTIMALWARE_COMMAND=clamscan --no-summary
