{
  "name": "mozacad/platform",
  "description": "Moz Acad - Plataforma inteligente de apoio à escrita científica",
  "type": "project",
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.9",
    "phpoffice/phpword": "^1.2",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if (!file_exists('.env')) copy('.env.example', '.env');\""
    ],
    "db:schema": [
      "@php database/setup.php --fresh"
    ],
    "db:setup": [
      "@php database/setup.php --fresh --seed"
    ],
    "db:upgrade": [
      "@php scripts/deploy_release.php"
    ],
    "ops:validate": [
      "@php scripts/validate_runtime.php"
    ],
    "ops:reconcile-successful-payments": [
      "@php scripts/reconcile_successful_payments.php"
    ],
    "deploy:release": [
      "@php scripts/deploy_release.php"
    ],
    "workers:run": [
      "@php scripts/run_workers.php"
    ],
    "workers:once": [
      "@php scripts/run_workers.php --once"
    ],
    "queue:status": [
      "@php scripts/queue_status.php"
    ]
  }
}
